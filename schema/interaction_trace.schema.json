{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solomon/specs/interaction_trace.schema.json",
  "title": "Solomon interaction_trace.json schema",
  "description": "Authoritative turn-by-turn record of the mediation session. Each turn records role, phase, message summary, state delta, and risk/escalation signals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "session_id",
    "policy_profile",
    "trace_created_at",
    "turns"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "interaction_trace.v0"
    },
    "case_id": { "type": "string" },
    "session_id": { "type": "string" },
    "policy_profile": { "type": "string" },
    "trace_created_at": { "type": "string" },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/turn" }
    },
    "final_state_summary": {
      "type": ["object", "null"],
      "description": "Quick evaluator review summary derived from session-end state. See CONTRACT-001 §5.7.",
      "additionalProperties": true,
      "properties": {
        "current_phase": { "type": "string" },
        "issues_identified": { "type": "array", "items": { "type": "string" } },
        "open_questions_remaining": { "type": "array", "items": { "type": "string" } },
        "active_flags": { "type": "array", "items": { "type": "string" } },
        "current_escalation_state": { "type": ["string", "null"] },
        "continuation_recommendation": { "type": ["string", "null"] }
      }
    },
    "trace_notes": {
      "type": ["string", "null"],
      "description": "Free-text note about trace conditions, omissions, or policy-driven limitations."
    }
  },
  "$defs": {
    "turn": {
      "type": "object",
      "required": ["turn_index", "timestamp", "role", "phase", "message_summary", "state_delta", "risk_check"],
      "additionalProperties": true,
      "properties": {
        "turn_index": { "type": "integer", "minimum": 1 },
        "timestamp": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["assistant", "client"]
        },
        "phase": { "type": "string" },
        "message_summary": { "type": "string" },
        "state_delta": { "$ref": "#/$defs/stateDelta" },
        "risk_check": { "$ref": "#/$defs/riskCheck" },
        "candidate_escalation_mode": { "type": ["string", "null"] },
        "candidate_escalation_category": { "type": ["string", "null"] },
        "confidence_note": { "type": ["string", "null"] },
        "message_text": {
          "type": ["string", "null"],
          "description": "Actual text spoken to participants. Present for lm_runtime turns; null for deterministic simulation turns."
        },
        "interaction_observations_delta": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Turn-level interaction quality observations recorded by the runtime (e.g. pacing notes, register shifts). Empty list when none are present."
        },
        "plugin_assessment": { "type": ["object", "null"] },
        "reasoning_trace": {
          "type": ["object", "null"],
          "description": "Structured five-step reasoning trace for lm_runtime turns. Null for runtime, reference, mock_model, and varied_mock_model turns. CONTRACT-014 defines the full schema.",
          "additionalProperties": true,
          "properties": {
            "source": { "type": "string", "const": "lm_runtime" },
            "model_id": { "type": "string" },
            "perception": { "type": "object", "additionalProperties": true },
            "domain_analysis": { "type": "object", "additionalProperties": true },
            "option_scan": { "type": "object", "additionalProperties": true },
            "safety_assessment": { "type": "object", "additionalProperties": true },
            "response_synthesis": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },
    "stateDelta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "facts_added": { "type": "array", "items": { "type": "string" } },
        "facts_revised": { "type": "array", "items": { "type": "string" } },
        "facts_structured": { "type": "array" },
        "positions_added_or_updated": { "type": "array", "items": { "type": "string" } },
        "positions_structured": { "type": "array" },
        "open_questions_added": { "type": "array", "items": { "type": "string" } },
        "open_questions_resolved": { "type": "array", "items": { "type": "string" } },
        "missing_info_structured": { "type": "array" },
        "issue_map_updates": { "type": "array", "items": { "type": "string" } },
        "issue_updates_structured": { "type": "array" },
        "option_state_updates": { "type": "array", "items": { "type": "string" } },
        "packages_structured": { "type": "array" },
        "escalation_state_updates": { "type": "array", "items": { "type": "string" } }
      }
    },
    "riskCheck": {
      "type": "object",
      "required": ["triggered", "signals", "severity", "notes"],
      "additionalProperties": false,
      "properties": {
        "triggered": { "type": "boolean" },
        "signals": { "type": "array", "items": { "type": "string" } },
        "severity": { "type": "integer", "minimum": 0, "maximum": 5 },
        "notes": { "type": "string" }
      }
    }
  }
}
