{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solomon/specs/option_pool.schema.json",
  "title": "Solomon option_pool.json schema",
  "description": "Stage 4 session-level option pool: per-turn brainstormer candidates + domain expert candidates → qualification → response selection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "session_id",
    "generated_at",
    "source",
    "turns"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "option_pool.v0"
    },
    "case_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the session artifact was written."
    },
    "source": {
      "type": "string",
      "const": "lm_runtime"
    },
    "turns": {
      "type": "array",
      "description": "One entry per turn where Stage 4 option generation ran.",
      "items": {
        "$ref": "#/$defs/optionPoolTurn"
      }
    }
  },
  "$defs": {
    "optionPoolTurn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn_index",
        "option_readiness",
        "safety_veto_applied",
        "brainstormer_candidates",
        "domain_expert_candidates",
        "combined_pool_count",
        "domain_qualified",
        "domain_blocked",
        "presented_to_parties"
      ],
      "properties": {
        "turn_index": {
          "type": "integer",
          "minimum": 1
        },
        "option_readiness": {
          "type": "string",
          "enum": ["ready", "deferred", "blocked"],
          "description": "Inherited from domain_analysis for this turn."
        },
        "safety_veto_applied": {
          "type": "boolean",
          "description": "True if option_readiness is blocked for this turn."
        },
        "safety_veto_reason": {
          "type": ["string", "null"],
          "description": "Non-null when safety_veto_applied is true."
        },
        "brainstormer_candidates": {
          "type": "array",
          "description": "Raw output of option_generator.py for this turn.",
          "items": {
            "$ref": "#/$defs/generatedCandidate"
          }
        },
        "domain_expert_candidates": {
          "type": "array",
          "description": "Domain-practitioner candidates added by the domain reasoner (Option B).",
          "items": {
            "$ref": "#/$defs/generatedCandidate"
          }
        },
        "combined_pool_count": {
          "type": "integer",
          "minimum": 0,
          "description": "len(brainstormer_candidates) + len(domain_expert_candidates)."
        },
        "domain_qualified": {
          "type": "array",
          "description": "Candidates from the combined pool that passed domain qualification.",
          "items": {
            "$ref": "#/$defs/qualifiedCandidate"
          }
        },
        "domain_blocked": {
          "type": "array",
          "description": "Candidates reviewed but found not viable given current session state.",
          "items": {
            "$ref": "#/$defs/blockedCandidate"
          }
        },
        "presented_to_parties": {
          "type": ["array", "null"],
          "description": "candidate_id values included in the main model's response. Null when not yet determined. All values must appear in domain_qualified.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "generatedCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "label",
        "rationale",
        "party_interest_alignment",
        "related_issues",
        "source"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "description": "Unique identifier. e.g. opt-gen-001 or opt-dom-001."
        },
        "label": {
          "type": "string",
          "description": "Short name for the option."
        },
        "rationale": {
          "type": "string",
          "description": "Why this option addresses the parties' interests."
        },
        "party_interest_alignment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["party_a", "party_b"],
          "properties": {
            "party_a": {
              "type": "string"
            },
            "party_b": {
              "type": "string"
            }
          }
        },
        "related_issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source": {
          "type": "string",
          "enum": ["option_generator", "domain_reasoner"],
          "description": "Which pass generated this candidate."
        }
      }
    },
    "qualifiedCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "label",
        "source",
        "feasibility_rationale",
        "confidence"
      ],
      "properties": {
        "candidate_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["option_generator", "domain_reasoner"]
        },
        "feasibility_rationale": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "prerequisite_parameters": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "conditions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "blockedCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "label",
        "source",
        "blocking_rationale",
        "what_would_unblock"
      ],
      "properties": {
        "candidate_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["option_generator", "domain_reasoner"]
        },
        "blocking_rationale": {
          "type": "string"
        },
        "what_would_unblock": {
          "type": "string"
        }
      }
    }
  }
}
